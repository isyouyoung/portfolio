{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "checkJs": false,
    "allowJs": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"]
}
